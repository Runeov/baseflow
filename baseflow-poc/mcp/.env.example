# Baseflow MCP Server Environment Variables
# Copy this file to .env and fill in your site-specific values.
# Never commit .env to git.

# ----- Site Identity -----
SITE_ID=node-001
SITE_NAME=Baseflow Node 001

# GPS coordinates (used for solar irradiance calculations and weather API)
SITE_LATITUDE=13.7563
SITE_LONGITUDE=100.5018
SITE_TIMEZONE=Asia/Bangkok

# Installed PV capacity in kWp
SITE_CAPACITY_KWP=10.0

# ----- Modbus TCP (Solar Inverters) -----
# IP address of the inverter or RS485/Modbus TCP gateway
MODBUS_HOST=192.168.1.10
MODBUS_PORT=502
MODBUS_TIMEOUT=3.0

# Comma-separated Modbus unit IDs for each inverter
# Single inverter: "1"   |   Four inverters: "1,2,3,4"
INVERTER_UNIT_IDS=1

# ----- MQTT Broker -----
MQTT_HOST=localhost
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=baseflow/node

# ----- Telegram Alerts -----
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs (get via @userinfobot after starting your bot)
# Group chat IDs are negative numbers: -100123456789
TELEGRAM_ALERT_CHAT_IDS=

# ----- Forecast.Solar (optional paid tier) -----
# Leave blank to use free tier (12 req/hr, no key required)
# FORECAST_SOLAR_API_KEY=
